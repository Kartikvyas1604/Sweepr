# ─────────────────────────────────────────────
# Sweepr — Environment Variables
# ─────────────────────────────────────────────

# Supabase (Project Dashboard → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Upstash Redis (Console → Create Redis Database)
UPSTASH_REDIS_REST_URL=https://your-region.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token

# TxLINE World Cup API — Free Tier (https://txline.txodds.com)
# Network: "mainnet" or "devnet" — must match everything below
SOLANA_NETWORK=mainnet
# RPC URL for the chosen network
NEXT_PUBLIC_SOLANA_RPC=https://api.mainnet-beta.solana.com
# API origin (no /api suffix):
#   mainnet → https://txline.txodds.com
#   devnet  → https://txline-dev.txodds.com
TXLINE_BASE_URL=https://txline.txodds.com
# On-chain program ID:
#   mainnet → 9ExbZjAapQww1vfcisDmrngPinHTEfpjYRWMunJgcKaA
#   devnet  → 6pW64gN1s2uqjHkn1unFeEjAwJkPGHoppGvS715wyP2J
TXLINE_PROGRAM_ID=9ExbZjAapQww1vfcisDmrngPinHTEfpjYRWMunJgcKaA
# TxL token mint (Token-2022):
#   mainnet → Zhw9TVKp68a1QrftncMSd6ELXKDtpVMNuMGr1jNwdeL
#   devnet  → 4Zao8ocPhmMgq7PdsYWyxvqySMGx7xb9cMftPMkEokRG
TXLINE_TOKEN_MINT=Zhw9TVKp68a1QrftncMSd6ELXKDtpVMNuMGr1jNwdeL
# Service level: 1 (60s delayed, free) or 12 (real-time, free)
TXLINE_SERVICE_LEVEL=1
# Subscription duration in weeks (multiples of 4)
TXLINE_DURATION_WEEKS=4
# Comma-separated league IDs (empty = standard bundle)
TXLINE_LEAGUES=

# NOTE: The free tier API token is obtained at runtime via:
#   1. Guest JWT from POST /auth/guest/start
#   2. Sign subscription txSig + leagues + JWT
#   3. POST /api/token/activate
# No static API key is needed.

# JWT (generate with: openssl rand -base64 32)
JWT_SECRET=your-32-plus-char-random-secret
JWT_EXPIRY=86400

# Solana Oracle Keypair (base58-encoded secret key)
# Generate: solana-keygen grind --starts-with oracle:1
SETTLEMENT_KEYPAIR=your-base58-encoded-secret-key
ORACLE_PUBKEY=your-oracle-public-key
PROTOCOL_FEE_WALLET=wallet-for-5-percent-fees

# Sweepr Anchor Program ID (after deploying program)
SWEEPR_PROGRAM_ID=your-program-id

# Inngest (https://app.inngest.com)
INNGEST_EVENT_KEY=your-event-key
INNGEST_SIGNING_KEY=your-signing-key

# Public URL (used for Inngest callbacks)
NEXT_PUBLIC_APP_URL=https://sweepr.xyz
